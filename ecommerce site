<!DOCTYPE html>
<html>
<head>
  <title>Ephouria</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- HEADER -->
<header class="top-header">
  <div class="logo">ephouria</div>

  <div class="location">
    Deliver to <br><b>Guntur 522002</b>
  </div>

  <div class="search-bar">
    <select>
      <option>All</option>
    </select>
    <input type="text" placeholder="Search Ephouria.in">
    <button>🔍</button>
  </div>

  <div class="nav-right">
    <div>Hello, User<br><b>Account & Lists</b></div>
    <div>Returns<br><b>& Orders</b></div>
    <div class="cart">🛒 Cart (<span id="count">0</span>)</div>
  </div>
</header>

<!-- NAVBAR -->
<nav class="menu">
  <a href="#">☰ All</a>
  <a href="#">Fresh</a>
  <a href="#">Today's Deals</a>
  <a href="#">Electronics</a>
  <a href="#">Fashion</a>
  <a href="#">Home</a>
</nav>

<!-- BANNER -->
<div class="banner">
  <img id="banner-img" src="https://m.media-amazon.com/images/I/61lwJy4B8PL._SX500_.jpg">
</div>

<!-- PRODUCT SECTIONS -->
<div class="section">

  <div class="box">
    <h3>Continue shopping deals</h3>
    <img src="https://m.media-amazon.com/images/I/61CGHv6kmWL._SX209_.jpg">
  </div>

  <div class="box">
    <h3>Pick up where you left off</h3>
    <img src="https://m.media-amazon.com/images/I/71li-ujtlUL._UY205_.jpg">
  </div>

  <div class="box">
    <h3>Keep shopping for</h3>
    <img src="https://m.media-amazon.com/images/I/61bK6PMOC3L._SX200_.jpg">
  </div>

  <div class="box">
    <h3>Deals & Offers</h3>
    <img src="https://m.media-amazon.com/images/I/71jG+e7roXL._SX200_.jpg">
  </div>

</div>

<script src="script.js"></script>
</body>
</html>
ody {
  margin: 0;
  font-family: Arial;
  background: #e3e6e6;
}

/* HEADER */
.top-header {
  display: flex;
  align-items: center;
  background: #131921;
  color: white;
  padding: 10px;
  gap: 15px;
}

.logo {
  font-size: 22px;
  font-weight: bold;
}

.location {
  font-size: 12px;
}

.search-bar {
  display: flex;
  flex: 1;
}

.search-bar select {
  padding: 5px;
}

.search-bar input {
  flex: 1;
  padding: 8px;
}

.search-bar button {
  background: orange;
  border: none;
  padding: 8px;
}

.nav-right {
  display: flex;
  gap: 15px;
  font-size: 12px;
}

.cart {
  font-weight: bold;
}

/* NAVBAR */
.menu {
  background: #232f3e;
  padding: 10px;
}

.menu a {
  color: white;
  margin-right: 15px;
  text-decoration: none;
}

/* BANNER */
.banner img {
  width: 100%;
  height: 300px;
  object-fit: cover;
}

/* SECTIONS */
.section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  padding: 20px;
}

.box {
  background: white;
  padding: 15px;
}

.box img {
  width: 100%;
  height: 200px;
  object-fit: contain;
}
let cartCount = 0;
document.getElementById("count").innerText = cartCount;

// Banner Slider
let images = [
  "https://m.media-amazon.com/images/I/61lwJy4B8PL._SX300_.jpg",
  "https://m.media-amazon.com/images/I/71qid7QFWJL._SX300_.jpg"
];

let index = 0;

setInterval(() => {
  index = (index + 1) % images.length;
  document.getElementById("banner-img").src = images[index];
}, 3000);
